<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Vice.Ui.Pages.SfxsPage"
             xmlns:local="clr-namespace:Vice.Ui.Pages"
             xmlns:converters="clr-namespace:Vice.Ui.Converters"
             xmlns:controls="clr-namespace:Vice.Ui.Controls"
             xmlns:effects="clr-namespace:Vice.Ui.Controls.Effects"
             x:DataType="local:SfxsPage"
             xmlns:cp="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
             x:CompileBindings="True">
    
    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Button Grid.Row="0" CornerRadius="6" Margin="5,0,0,0" Click="NewItem" BorderBrush="{DynamicResource Opposite}" BorderThickness="1">
            <Button.Styles>
                <Style Selector="Button">
                    <Setter Property="Background" Value="{DynamicResource NotPressedBrush}"/>

                    <Style Selector="^:pointerover">
                        <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                    </Style>

                    <Style Selector="^:pressed">
                        <Setter Property="Background" Value="{DynamicResource PressedBrush}"/>
                    </Style>
                </Style>
            </Button.Styles>
            
            <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource add_regular}" />
                <TextBlock Text="New"/>
            </StackPanel>
        </Button>
        
        <Grid Grid.Row="1">
            <Grid IsVisible="{Binding Editing, Converter={StaticResource InverseBoolConverter}}">
                <ProgressBar Width="200"
                         Height="50"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsVisible="{Binding IsLoaded, Converter={StaticResource InverseBoolConverter}}"
                         IsIndeterminate="True"/>
            
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Items}"
                                  IsVisible="{Binding IsLoaded}"
                                  Margin="5">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="{Binding ColumnCount}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
    
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:SfxItemTemplate">
                                <Border Background="{Binding Brush}"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="8"
                                        Tag="{Binding name}"
                                        Margin="4">

                                    <Border.Height>
                                        <Binding Path="Bounds.Width"
                                                 RelativeSource="{RelativeSource Self}" />
                                    </Border.Height>
                                    
                                    <Grid>
                                        <Viewbox Stretch="Uniform"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Bottom"
                                                 Margin="0 0 0 8"
                                                 Height="48">
                                            <TextBlock Text="{Binding name}" Foreground="{Binding LightOrDarkIconColor}"/>
                                        </Viewbox>
                                        
                                        <Viewbox Stretch="Uniform" Margin="60 8 64 40" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <PathIcon Data="{Binding Icon}"
                                                      Foreground="White"/>
                                        </Viewbox>
                                        
                                        <Button HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0 16 8 0"
                                                Background="Transparent"
                                                Click="MoreButton">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Delete" Click="DeleteItem"/>
                                                    <MenuItem Header="Edit" Click="EditItem"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            
                                            <PathIcon Data="{StaticResource more_vertical_regular}"
                                                      Width="24"
                                                      Height="24"
                                                      Foreground="{Binding LightOrDarkIconColor}"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            
            <DockPanel Margin="20" IsVisible="{Binding Editing}">
                <Grid DockPanel.Dock="Bottom" VerticalAlignment="Bottom" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" CornerRadius="6" Margin="0,0,16,0" Click="SaveButtonClick" BorderBrush="{DynamicResource Opposite}" BorderThickness="1">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Background" Value="{DynamicResource NotPressedBrush}"/>

                                <Style Selector="^:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                </Style>

                                <Style Selector="^:pressed">
                                    <Setter Property="Background" Value="{DynamicResource PressedBrush}"/>
                                </Style>
                            </Style>
                        </Button.Styles>
                        
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource save_regular}" />
                            <TextBlock Text="Save"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Grid.Column="1" CornerRadius="6" Margin="0,0,16,0" Click="BackButtonClick" BorderBrush="{DynamicResource Opposite}" BorderThickness="1">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Background" Value="{DynamicResource NotPressedBrush}"/>

                                <Style Selector="^:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                </Style>

                                <Style Selector="^:pressed">
                                    <Setter Property="Background" Value="{DynamicResource PressedBrush}"/>
                                </Style>
                            </Style>
                        </Button.Styles>
                        
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource arrow_left_regular}" />
                            <TextBlock Text="Back"/>
                        </StackPanel>
                    </Button>
                </Grid>
                
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0"
                                Width="96"
                                Height="96"
                                CornerRadius="96"
                                Background="Transparent"
                                Margin="0 0 16 0">
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <cp:ColorView Width="360"
                                                  Height="330"
                                                  Color="{Binding EditedItemTemplate.Color, Mode=TwoWay}"
                                                  IsAlphaEnabled="False"
                                                  Opacity="1"
                                                  IsComponentSliderVisible="False"
                                                  IsColorPaletteVisible="False"
                                                  IsHexInputVisible="False"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>
                                </Flyout>
                            </Button.Flyout>
                            
                            <PathIcon Data="{StaticResource color_regular}" Width="84" Height="84"></PathIcon>
                        </Button>
                        
                        <TextBox Grid.Column="1"
                                 Text="{Binding EditedItemTemplate.name, Mode=TwoWay}"
                                 Watermark="Name"
                                 Height="40"
                                 Background="{DynamicResource NotPressedBrush}"
                                 BorderBrush="{DynamicResource Opposite}"
                                 BorderThickness="1"
                                 HorizontalAlignment="Stretch"
                                 CornerRadius="8"/>
                    </Grid>
    
                    <Border Height="20"/>
                    
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0"
                                Width="96"
                                Height="96"
                                CornerRadius="96"
                                Background="Transparent"
                                Margin="0 0 16 0">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <controls:IconSelection Clicked="IconSelected"/>
                                </MenuFlyout>
                            </Button.Flyout>
                            
                            <PathIcon Data="{Binding EditedItemTemplate.Icon}" Width="84" Height="84"></PathIcon>
                        </Button>
                        
                        <controls:KeybindListener Grid.Column="1"
                                                  BorderBrush="{DynamicResource Opposite}"
                                                  BorderThickness="1"
                                                  HorizontalAlignment="Stretch"
                                                  Text="{Binding EditedItemTemplate.KeysText}"
                                                  Height="40"
                                                  CornerRadius="8"
                                                  x:Name="Keybinds"/>
                    </Grid>
                    
                    <Border Height="20"/>
                    
                    <Grid VerticalAlignment="Center">
                        <TextBlock Text="Low latency mode" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <ToggleSwitch IsChecked="{Binding EditedItemTemplate.lowlatency}" Margin="0,0,20,0" HorizontalAlignment="Right"/>
                    </Grid>
                    
                    <Border Height="20"/>
                    
                    <Button Height="40"
                            CornerRadius="8"
                            HorizontalAlignment="Stretch"
                            BorderBrush="{DynamicResource Opposite}"
                            BorderThickness="1"
                            Click="SoundFile">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Background" Value="{DynamicResource NotPressedBrush}"/>

                                <Style Selector="^:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                </Style>

                                <Style Selector="^:pressed">
                                    <Setter Property="Background" Value="{DynamicResource PressedBrush}"/>
                                </Style>
                            </Style>
                        </Button.Styles>
                        
                        <Grid>
                            <TextBlock x:Name="AudioFileText"
                                       Text="Click to select an audio file"
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       IsVisible="{Binding EditedItemTemplate.IsVolumeVisible, Converter={StaticResource InverseBoolConverter}}"/>
                            <Grid x:Name="VolumeIndicatorFile"
                                  ColumnDefinitions="*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*"
                                  IsVisible="{Binding EditedItemTemplate.IsVolumeVisible}"></Grid>
                        </Grid>
                        
                    </Button>
                        
                    <Border Height="20"/>
                    
                    <effects:Effects Height="150" HorizontalAlignment="Stretch" x:Name="EffectsUi"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>